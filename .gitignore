# Claude / AI assistant context — local only, never track
CLAUDE.md
.claude/
.cursor/
.aider*

# Design / implementation / planning docs — local only
/docs/
docs/*
*.design.md
*.implementation.md

# Security scan output — local only
scans/

# Build output
/dist/
/bin/
/build/

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum
vendor/

# Secrets / credentials / certs — never commit
*.pem
*.key
*.crt
*.cert
*.trust
/creds/
.env
.env.*
!.env.example

# Runtime data / databases
/data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Frontend
web/dist/
web/node_modules/
web/.vite/
*.log
npm-debug.log*

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Embedded SPA build output (built in CI/release; keep the placeholder)
/internal/webui/dist/*
